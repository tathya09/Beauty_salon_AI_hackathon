{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./scripts/dist"
  },
  "include": [
    "scripts/**/*.ts",
    "src/utils/**/*.ts",
    "src/types/**/*.ts",
    "src/types/**/*.d.ts"
  ]
}
